# Copy to `.env` and fill in for local dev. Defaults in compose work out of the
# box; this file documents what you CAN override.

# Server
PORT=3001
NODE_ENV=development

# Auth — JWT signing key. Required in production; dev falls back to an
# unsafe literal if unset. Never ship without setting this in prod.
JWT_SECRET=

# Schema version — normally set from $(git rev-parse --short HEAD) at build
# time; defaults to the literal "dev" so OPFS doesn't wipe on every save.
APP_SCHEMA_VERSION=dev

# Turso (production). Leave unset for local dev — compose runs sqld instead.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional debug metrics token. When NODE_ENV=production, /api/debug/metrics
# is 404'd unless ?token matches this value.
DEBUG_TOKEN=
